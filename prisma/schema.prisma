generator client {
  provider = "prisma-client-js"
  engineType ="client"
}

datasource db {
  provider = "postgresql"
}

model Property{
  id String @id @default(cuid())
  slug String @unique
  title String
  price Float?
  category Category
  description String
  images String[]
  bedrooms Int?
  coveredArea Int?
  semiCoveredArea Int?
  lotArea Int?
  neighborhood String?
  zone String?
  pool Boolean @default(false)
  financing Boolean @default(false)
  mortgageEligible Boolean @default(false)
  featured Boolean @default(false)
  createdAt DateTime @default(now())
}

enum Category{
  houses
  lots
  local
}